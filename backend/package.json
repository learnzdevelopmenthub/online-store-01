{
  "name": "@store/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "argon2": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "5.2.0",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "latest",
    "helmet": "^8.0.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.4.1",
    "mongoose-paginate-v2": "^1.9.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "razorpay": "2.9.6",
    "sharp": "latest",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.0",
    "msw": "^2.6.0",
    "nodemon": "^3.1.7",
    "supertest": "7.2.2",
    "tsx": "^4.19.2",
    "vitest": "^4.0.0"
  }
