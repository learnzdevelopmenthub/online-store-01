# Backend environment variables.
# Copy to .env and fill in real values for local development.
# See docs/MILESTONES.md (Appendix: Environment Variables Reference) for the
# canonical list and intended use of each key.

# --- Runtime ---
NODE_ENV=development
PORT=5000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/online-store-01

# --- Auth (RS256 JWT + refresh token hashing) ---
# Generate keys with: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
# and: openssl rsa -pubout -in private.pem -out public.pem
# Paste PEM contents as a single line with \n for newlines, or use a multi-line .env loader.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
REFRESH_TOKEN_SECRET=

# --- Google One Tap ---
GOOGLE_CLIENT_ID=

# --- Razorpay (payments + webhooks) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=books-public
R2_PRIVATE_BUCKET=books-private
R2_PUBLIC_URL=https://cdn.example.com

# --- Email (Nodemailer SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Admin seeding ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- CORS (comma-separated origins) ---
# Docker nginx ports (3000/3001) + native Vite dev servers (5173 buyer, 5174 admin).
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174
