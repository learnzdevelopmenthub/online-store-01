# Buyer App environment variables.
# Copy to .env and fill in real values for local development.
# Only VITE_-prefixed variables are exposed to the browser bundle.
# See docs/MILESTONES.md (Appendix: Environment Variables Reference) for the
# canonical list and intended use of each key.

# --- Backend ---
VITE_API_URL=http://localhost:5000

# --- Google One Tap (OAuth client ID, safe to expose) ---
VITE_GOOGLE_CLIENT_ID=

# --- Razorpay (public key, safe to expose) ---
VITE_RAZORPAY_KEY=
