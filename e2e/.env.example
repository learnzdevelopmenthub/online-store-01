# E2E test environment variables.
# Copy to .env and fill in real values for local development.
# These URLs must point at already-running dev servers; Playwright does not
# auto-start them. Start each app's dev server in a separate terminal before
# running `npm run test:e2e`.
# See docs/MILESTONES.md (Appendix: Environment Variables Reference) for the
# canonical list and intended use of each key.

# --- App URLs ---
VITE_BUYER_URL=http://localhost:5173
VITE_ADMIN_URL=http://localhost:5174
