# Runtime
NODE_ENV=production
PORT=5000

# Database — points at the `mongo` service over docker DNS
MONGODB_URI=mongodb://mongo:27017/online-store-01

# Auth (RS256 JWT) — inline PEM with literal \n escapes
# Generate: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:4096
#           openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
REFRESH_TOKEN_SECRET=

# Google OAuth (M5)
GOOGLE_CLIENT_ID=

# Razorpay (M8)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2 (M6)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_COVERS=
R2_BUCKET_PDFS=
R2_PUBLIC_URL=

# SMTP (M12)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Admin seed (M5)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS — comma-separated origins for the two frontends
# Not wired in the backend yet (M5); set anyway so we don't revisit compose
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
